cAAc;AAAA,QAAA;AAAA,MACzC;AAAA,IACF,CACD;AAED,UAAM,qBAAqB;AAAA,MACzB;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,IAAA;AAGF,UAAM,kBAAkB,CAAC,uBAAuB,mBAAmB,mBAAmB,eAAe;AAErG,UAAM,iBAAiB;AAAA,MACrB,EAAE,SAAS,wBAAwB,YAAY,MAAM,SAAS,MAAA;AAAA,MAC9D,EAAE,SAAS,qBAAqB,YAAY,MAAM,SAAS,MAAA;AAAA,MAC3D,EAAE,SAAS,2BAA2B,YAAY,MAAM,SAAS,MAAA;AAAA,MACjE,EAAE,SAAS,kCAAkC,YAAY,MAAM,SAAS,MAAA;AAAA,MACxE,EAAE,SAAS,cAAc,YAAY,MAAM,SAAS,MAAA;AAAA,MACpD,EAAE,SAAS,oBAAoB,YAAY,MAAM,SAAS,MAAA;AAAA,MAC1D,EAAE,SAAS,oBAAoB,YAAY,MAAM,SAAS,MAAA;AAAA,IAAM;AAGlE,UAAM,iBAAiB,IAAI,IAAI;AAE/B,UAAM,OAAO;AAAA,MACX;AAAA,QACE,GAAG;AAAA,QACH,GAAG;AAAA,MAAA;AAAA,MAEL;AAAA,QACE,GAAG;AAAA,QACH,GAAG;AAAA,MAAA;AAAA,MAEL;AAAA,QACE,GAAG;AAAA,QACH,GAAG;AAAA,MAAA;AAAA,IACL;;;;;AAMK,YAAA,OAAAL,eAAAC,WAAA,EAAA,OAAM,kBAAc,MAAA,CAAA,CAAA,gaAAA;;oBAQKC,MAAA,cAAA;AAAA,mEAAA,eAAc,QAAA,SAAA;AAAA,QAAE,UAAA;AAAA,MAAA;;;QAMtC,MAAK;AAAA,QACJ,UAAU;AAAA,QACX,aAAU;AAAA,QACV,YAAS;AAAA,QACT,aAAU;AAAA,QACV,iBAAc;AAAA,MAAA;;QAGd,MAAK;AAAA,QACJ,UAAU;AAAA,QACV,UAAU;AAAA,QACX,aAAU;AAAA,QACV,YAAS;AAAA,QACT,oBAAiB;AAAA,QACjB,4BAAyB;AAAA,QACzB,iBAAc;AAAA,QACd,iBAAc;AAAA,MAAA;;AAoBMI,oBAAA,iBAAP,QAAG;AAIgD,cAAA,mGAAAH,eAAA,IAAI,OAAO,CAAA,6BAAA;AAEvD,YAAA,IAAI,YAAU;;;;;;AAId,YAAA,IAAI,SAAO;;;;;;;;AAgBfG,oBAAA,OAAP,QAAG;gLAIoDH,eAAA,IAAI,CAAC,kEACPA,eAAA,IAAI,CAAC;;;;QAOnE,IAAG;AAAA,QACH,OAAM;AAAA,MAAA;yBAFR,CAKW,GAAAC,QAAAC,UAAA,aAAA;;;;;8BAFV,uBAED;AAAA,YAAA;AAAA;;;;;;;;;;;;;;","names":["_useModel","_ssrRenderAttrs","_mergeProps","_unref","_ssrInterpolate","_push","_parent","_ssrRenderList"],"sources":["../../../../components/PriceToggle.vue","../../../../components/PricingCard.vue","../../../../pages/pricing.vue"],"sourcesContent":["<script setup lang=\"ts\">\nconst model = defineModel<boolean>({ default: false })\ndefineProps<{\n  disabled?: boolean\n  monthlyLabel?: string\n  annualLabel?: string\n}>()\n</script>\n\n<template>\n  <div class=\"inline-flex items-center gap-2 rounded-full bg-gray-100 dark:bg-gray-800 p-1\">\n    <button\n      type=\"button\"\n      class=\"rounded-full px-4 py-2 text-sm font-medium transition-all\"\n      :class=\"\n        !model\n          ? 'bg-white dark:bg-gray-700 text-primary-dark dark:text-accent-teal shadow'\n          : 'text-gray-600 dark:text-gray-400'\n      \"\n      :disabled=\"disabled\"\n      @click=\"model = false\"\n    >\n      {{ monthlyLabel ?? 'Monthly' }}\n    </button>\n    <button\n      type=\"button\"\n      class=\"rounded-full px-4 py-2 text-sm font-medium transition-all\"\n      :class=\"\n        model\n          ? 'bg-white dark:bg-gray-700 text-primary-dark dark:text-accent-teal shadow'\n          : 'text-gray-600 dark:text-gray-400'\n      \"\n      :disabled=\"disabled\"\n      @click=\"model = true\"\n    >\n      {{ annualLabel ?? 'Annual' }}\n    </button>\n    <span\n      v-if=\"disabled\"\n      class=\"ml-2 text-xs text-gray-500 dark:text-gray-400\"\n    >\n      (Monthly only for now)\n    </span>\n  </div>\n</template>\n","<script setup lang=\"ts\">\ninterface PricingFeature {\n  text: string\n}\n\ninterface Props {\n  plan: string\n  featured?: boolean\n  features: PricingFeature[] | string[]\n  ctaLabel: string\n  ctaLink: string\n  onboardingPrice?: string\n  onboardingStrikethrough?: string\n  savingsBadge?: string\n  monthlyPrice: string\n  setupFee?: string\n}\n\nconst props = withDefaults(defineProps<Props>(), {\n  featured: false,\n  onboardingPrice: '',\n  onboardingStrikethrough: '',\n  savingsBadge: '',\n  setupFee: '',\n})\n\nconst featureList = computed(() =>\n  props.features.map((f) => (typeof f === 'string' ? { text: f } : f))\n)\n</script>\n\n<template>\n  <div\n    class=\"relative rounded-2xl border-2 p-6 sm:p-8 transition-all duration-300 hover:shadow-xl flex flex-col h-full\"\n    :class=\"\n      featured\n        ? 'border-accent-teal bg-primary-dark dark:bg-primary-dark/90 text-white shadow-lg scale-[1.02]'\n        : 'border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800/50 hover:border-accent-teal/50'\n    \"\n  >\n    <div v-if=\"savingsBadge\" class=\"absolute -top-3 left-1/2 -translate-x-1/2\">\n      <span\n        class=\"inline-block rounded-full bg-accent-gold px-3 py-1 text-xs font-semibold text-primary-dark\"\n      >\n        {{ savingsBadge }}\n      </span>\n    </div>\n\n    <h3\n      class=\"text-xl font-bold\"\n      :class=\"featured ? 'text-white' : 'text-primary-dark dark:text-accent-teal'\"\n    >\n      {{ plan }}\n    </h3>\n\n    <div class=\"mt-4 flex flex-wrap items-baseline gap-2\">\n      <template v-if=\"onboardingStrikethrough\">\n        <span\n          class=\"text-lg\"\n          :class=\"featured ? 'text-white/80 line-through' : 'text-gray-500 dark:text-gray-400 line-through'\"\n        >\n          {{ onboardingStrikethrough }}\n        </span>\n        <span\n          class=\"text-2xl font-bold\"\n          :class=\"featured ? 'text-white' : 'text-primary-dark dark:text-accent-teal'\"\n        >\n          {{ onboardingPrice }}\n        </span>\n        <span :class=\"featured ? 'text-white/80' : 'text-gray-600 dark:text-gray-400'\">\n          onboarding\n        </span>\n      </template>\n      <template v-if=\"setupFee && !onboardingStrikethrough\">\n        <span\n          class=\"text-lg font-semibold\"\n          :class=\"featured ? 'text-white' : 'text-primary-dark dark:text-accent-teal'\"\n        >\n          {{ setupFee }}\n        </span>\n        <span :class=\"featured ? 'text-white/80' : 'text-gray-600 dark:text-gray-400'\">\n          setup\n        </span>\n      </template>\n    </div>\n\n    <div class=\"mt-2\">\n      <span\n        class=\"text-2xl font-bold\"\n        :class=\"featured ? 'text-white' : 'text-primary-dark dark:text-accent-teal'\"\n      >\n        {{ monthlyPrice }}\n      </span>\n      <span :class=\"featured ? 'text-white/80' : 'text-gray-600 dark:text-gray-400'\">/month</span>\n    </div>\n\n    <ul class=\"mt-6 flex-1 space-y-3\">\n      <li\n        v-for=\"(feature, i) in featureList\"\n        :key=\"i\"\n        class=\"flex items-start gap-2 text-sm\"\n        :class=\"featured ? 'text-white/90' : 'text-gray-700 dark:text-gray-300'\"\n      >\n        <span class=\"mt-0.5 shrink-0 text-accent-teal\" :class=\"featured ? 'text-accent-gold' : ''\">\n          ✓\n        </span>\n        {{ feature.text }}\n      </li>\n    </ul>\n\n    <NuxtLink\n      :to=\"ctaLink\"\n      class=\"mt-8 inline-flex justify-center rounded-lg px-6 py-3 text-center font-semibold transition-all duration-200 hover:scale-[1.02]\"\n      :class=\"\n        featured\n          ? 'bg-accent-teal text-white hover:bg-accent-teal/90 shadow-md'\n          : 'bg-primary-dark dark:bg-accent-teal text-white hover:opacity-90'\n      \"\n    >\n      {{ ctaLabel }}\n    </NuxtLink>\n  </div>\n</template>\n","<script setup lang=\"ts\">\nconst structuredData = {\n  '@context': 'https://schema.org',\n  '@graph': [\n    {\n      '@type': 'Product',\n      name: 'AYADMO Analytics Enterprise',\n      description: 'Full platform access with unlimited uploads, all economic indicators, ML models, 5-year forecasts, API, and priority support.',\n      offers: {\n        '@type': 'Offer',\n        price: '25',\n        priceCurrency: 'USD',\n        priceValidUntil: new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),\n      },\n    },\n    {\n      '@type': 'Product',\n      name: 'AYADMO Analytics Starter',\n      description: 'Basic analysis with limited uploads and core indicators.',\n      offers: {\n        '@type': 'Offer',\n        price: '15',\n        priceCurrency: 'USD',\n        priceValidUntil: new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),\n      },\n    },\n  ],\n}\n\nuseHead({\n  title: 'Pricing – AYADMO Analytics',\n  meta: [\n    {\n      name: 'description',\n      content:\n        'Enterprise and Starter plans. Full platform access, unlimited uploads, 5-year forecasts, API, and priority support.',\n    },\n  ],\n  link: [{ rel: 'canonical', href: 'https://ayadmo-analytics.com/pricing' }],\n  script: [\n    {\n      type: 'application/ld+json',\n      children: JSON.stringify(structuredData),\n    },\n  ],\n})\n\nconst enterpriseFeatures = [\n  'Full platform access',\n  'Unlimited data uploads',\n  'All economic indicators',\n  'Advanced ML models',\n  '5-year forecasts',\n  'API access',\n  'Priority support',\n  'Custom reporting',\n]\n\nconst starterFeatures = ['Basic analysis only', 'Limited uploads', 'Core indicators', 'Email support']\n\nconst comparisonRows = [\n  { feature: 'Full platform access', enterprise: true, starter: false },\n  { feature: 'Unlimited uploads', enterprise: true, starter: false },\n  { feature: 'All economic indicators', enterprise: true, starter: false },\n  { feature: 'Advanced ML & 5-year forecasts', enterprise: true, starter: false },\n  { feature: 'API access', enterprise: true, starter: false },\n  { feature: 'Priority support', enterprise: true, starter: false },\n  { feature: 'Custom reporting', enterprise: true, starter: false },\n]\n\nconst billingMonthly = ref(true)\n\nconst faqs = [\n  {\n    q: 'Can I switch plans later?',\n    a: 'Yes. You can upgrade from Starter to Enterprise at any time. We will prorate the onboarding fee.',\n  },\n  {\n    q: 'What payment methods do you accept?',\n    a: 'We accept major credit cards and bank transfer for annual commitments.',\n  },\n  {\n    q: 'Is there a free trial?',\n    a: 'Contact us for a tailored demo and trial period for Enterprise.',\n  },\n]\n\n</script>\n\n<template>\n  <div class=\"min-h-screen\">\n    <div class=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16\">\n      <header class=\"text-center mb-12\">\n        <h1 class=\"text-4xl font-bold text-primary-dark dark:text-accent-teal\">Pricing</h1>\n        <p class=\"mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto\">\n          Choose the plan that fits your export intelligence needs. Start with Starter or go full power with Enterprise.\n        </p>\n        <div class=\"mt-6 flex justify-center\">\n          <PriceToggle v-model=\"billingMonthly\" disabled />\n        </div>\n      </header>\n\n      <div class=\"grid md:grid-cols-2 gap-8 max-w-4xl mx-auto\">\n        <PricingCard\n          plan=\"Starter\"\n          :features=\"starterFeatures\"\n          cta-label=\"Get Started\"\n          cta-link=\"#signup\"\n          setup-fee=\"$500\"\n          monthly-price=\"$15.00\"\n        />\n        <PricingCard\n          plan=\"Enterprise\"\n          :featured=\"true\"\n          :features=\"enterpriseFeatures\"\n          cta-label=\"Start Your Analysis\"\n          cta-link=\"#signup\"\n          onboarding-price=\"$1,400.00\"\n          onboarding-strikethrough=\"$1,500.00\"\n          savings-badge=\"Save $100.00 on onboarding\"\n          monthly-price=\"$25.00\"\n        />\n      </div>\n\n      <!-- Comparison table -->\n      <section class=\"mt-16\">\n        <h2 class=\"text-2xl font-bold text-primary-dark dark:text-accent-teal text-center mb-8\">\n          Enterprise vs Starter\n        </h2>\n        <div class=\"overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700 max-w-2xl mx-auto\">\n          <table class=\"w-full text-left\">\n            <thead class=\"bg-gray-50 dark:bg-gray-800\">\n              <tr>\n                <th class=\"px-4 py-3 font-semibold text-gray-900 dark:text-gray-100\">Feature</th>\n                <th class=\"px-4 py-3 font-semibold text-primary-dark dark:text-accent-teal\">Enterprise</th>\n                <th class=\"px-4 py-3 font-semibold text-gray-700 dark:text-gray-300\">Starter</th>\n              </tr>\n            </thead>\n            <tbody class=\"divide-y divide-gray-200 dark:divide-gray-700\">\n              <tr\n                v-for=\"row in comparisonRows\"\n                :key=\"row.feature\"\n                class=\"bg-white dark:bg-gray-800/50\"\n              >\n                <td class=\"px-4 py-3 text-gray-700 dark:text-gray-300\">{{ row.feature }}</td>\n                <td class=\"px-4 py-3\">\n                  <span v-if=\"row.enterprise\" class=\"text-accent-teal font-medium\">✓</span>\n                  <span v-else class=\"text-gray-400\">—</span>\n                </td>\n                <td class=\"px-4 py-3\">\n                  <span v-if=\"row.starter\" class=\"text-accent-teal font-medium\">✓</span>\n                  <span v-else class=\"text-gray-400\">—</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </section>\n\n      <!-- FAQ -->\n      <section class=\"mt-16 max-w-2xl mx-auto\">\n        <h2 class=\"text-2xl font-bold text-primary-dark dark:text-accent-teal text-center mb-8\">\n          Pricing FAQ\n        </h2>\n        <ul class=\"space-y-6\">\n          <li\n            v-for=\"faq in faqs\"\n            :key=\"faq.q\"\n            class=\"rounded-xl border border-gray-200 dark:border-gray-700 p-4 bg-white dark:bg-gray-800/50\"\n          >\n            <h3 class=\"font-semibold text-gray-900 dark:text-gray-100\">{{ faq.q }}</h3>\n            <p class=\"mt-2 text-sm text-gray-600 dark:text-gray-400\">{{ faq.a }}</p>\n          </li>\n        </ul>\n      </section>\n\n      <div id=\"signup\" class=\"mt-16 text-center\">\n        <NuxtLink\n          to=\"#signup\"\n          class=\"inline-flex rounded-lg bg-primary-dark dark:bg-accent-teal px-8 py-4 font-semibold text-white transition hover:opacity-90\"\n        >\n          Start Your Analysis\n        </NuxtLink>\n      </div>\n    </div>\n  </div>\n</template>\n"],"version":3}